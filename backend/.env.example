# ─── Environnement ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de données PostgreSQL ──────────────────────────────────
DATABASE_URL="postgresql://flashdoc_user:flashdoc_pass@localhost:5432/flashdoc_db"

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_KEY_IN_PRODUCTION
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP SMS (Twilio ou autre provider SMS) ──────────────────────
# Remplace par ton provider SMS camerounais si disponible
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Mobile Money ────────────────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_CLIENT_ID=your_orange_client_id
ORANGE_MONEY_CLIENT_SECRET=your_orange_client_secret
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key

MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_API_USER=your_api_user
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox

# ─── Fichiers / Upload ───────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# ─── Commission plateforme ───────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.25

# ─── Dispatch ────────────────────────────────────────────────────
DISPATCH_TIMEOUT_SECONDS=60
DISPATCH_MAX_RETRIES=3

# ─── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
