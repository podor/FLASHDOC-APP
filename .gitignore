# ══════════════════════════════════════════════════════
# FlashDoc — .gitignore
# ══════════════════════════════════════════════════════

# ── Secrets & env ──────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
deploy/.env
# Garder le template d'exemple
!deploy/.env.production

# ── Node.js ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Uploads (générés à l'exécution) ───────────────────
backend/uploads/
uploads/

# ── Prisma (généré) ────────────────────────────────────
backend/node_modules/
backend/generated/

# ── Flutter / Dart ─────────────────────────────────────
patient_app/.dart_tool/
patient_app/.flutter-plugins
patient_app/.flutter-plugins-dependencies
patient_app/build/
patient_app/.packages
patient_app/pubspec.lock

# ── Android ────────────────────────────────────────────
patient_app/android/.gradle/
patient_app/android/local.properties
patient_app/android/key.properties
*.keystore
*.jks

# ── IDE ────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Images & médias temporaires ────────────────────────
*.jpeg
*.jpg
*.png
!patient_app/assets/**
!patient_app/android/app/src/main/res/**
!deploy/nginx-flashdoc.conf

# ── Docker ─────────────────────────────────────────────
# (on garde les Dockerfiles et docker-compose)

# ── Fichiers Windows temporaires ───────────────────────
*.bat
*.ps1
