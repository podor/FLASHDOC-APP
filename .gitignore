# ══════════════════════════════════════════════════════
# FlashDoc — .gitignore
# ══════════════════════════════════════════════════════

# ── Secrets (JAMAIS dans Git) ─────────────────────────
.env
.env.local
backend/.env
# Garder le template avec les valeurs vides
!deploy/.env.production

# ── Node.js ────────────────────────────────────────────
node_modules/
npm-debug.log*
*.log

# ── Uploads ────────────────────────────────────────────
backend/uploads/
uploads/

# ── Flutter / Dart ─────────────────────────────────────
patient_app/.dart_tool/
patient_app/.flutter-plugins
patient_app/.flutter-plugins-dependencies
patient_app/build/
patient_app/.packages
patient_app/pubspec.lock

# ── Android ────────────────────────────────────────────
patient_app/android/.gradle/
patient_app/android/local.properties
patient_app/android/key.properties
*.keystore
*.jks

# ── IDE ────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Médias racine (non liés au code) ───────────────────
/*.jpeg
/*.jpg
/*.png
/*.docx
/*.svg
/*.bat
/*.ps1

# ── Docker (on garde les fichiers de config) ───────────
# docker-compose.yml et Dockerfile sont versionnés
